# Copy this file to .env and replace the placeholder cloud values locally.
PROJECT_NAME=magic-zoomcamp
MAGE_ENV_FILE=.env

# Local PostgreSQL service used by Mage.
POSTGRES_DBNAME=postgres
POSTGRES_SCHEMA=magic
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Public placeholders only. Put real values in the ignored .env file.
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-globally-unique-bucket-name
GOOGLE_LOCATION=EU

# Host path to a local key. The file is mounted read-only into the container.
# Prefer Application Default Credentials or workload identity outside this
# local learning setup.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./keys/service-account.json
